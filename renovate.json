{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "dependencyDashboard": false,
  "tekton": {
    "fileMatch": ["\\.yaml$", "\\.yml$"],
    "includePaths": [
      ".tekton/**",
      "pipeline/**",
      "task/**"
    ]
  },
  "prConcurrentLimit": 1
}
